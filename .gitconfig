[user]
  name = Danny Tatom
  email = its.danny@hey.com

[github]
  user = its-danny

[credential "https://github.com"]
  helper = !gh auth git-credential

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[init]
	defaultBranch = main
